:root {
}

.test-title {
    font-size: 75px;
    -unity-text-align: middle-center;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap-BoldItalic.ttf?fileID=12800000&guid=6792dbba7e995324b9ab819d40bb30ce&type=3#Asap-BoldItalic");
    color: rgb(255, 255, 255);
}

.scene-title {
    font-size: 50px;
    -unity-text-align: middle-center;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap-Bold.ttf?fileID=12800000&guid=e444fa282e47abb4da37b5ca65644d44&type=3#Asap-Bold");
    color: rgb(255, 255, 255);
}

.unity-base-field__label {
    font-size: 40px;
    color: rgb(255, 255, 255);
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap-MediumItalic.ttf?fileID=12800000&guid=8b32abadc7a10574fb6b083c7dbd96e0&type=3#Asap-MediumItalic");
    -unity-text-align: middle-center;
    -unity-font-style: bold;
}

.unity-radio-button__label {
    font-size: 35px;
    -unity-text-align: upper-left;
    -unity-font-style: normal;
}

.button-play {
    font-size: 35px;
    -unity-text-align: middle-center;
    padding-top: 25px;
    padding-right: 75px;
    padding-bottom: 25px;
    padding-left: 75px;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_Condensed-SemiBold.ttf?fileID=12800000&guid=6bdc3438c3d6c70489258aec63575da4&type=3#Asap_Condensed-SemiBold");
    border-left-color: rgba(0, 0, 0, 0);
    border-right-color: rgba(0, 0, 0, 0);
    border-top-color: rgba(0, 0, 0, 0);
    border-bottom-color: rgba(0, 0, 0, 0);
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Source_Image_Sprites/extra%20large/extra-long-yellow-extra-large.png?fileID=2800000&guid=b84980f08f533b445b41ce88a4636b83&type=3#extra-long-yellow-extra-large");
    background-color: rgba(0, 0, 0, 0);
}

.button-play:hover {
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Highlighted_Sprite/extra%20large/extra-long-yellow-highlight-extra-large.png?fileID=2800000&guid=eef1a32eaf29f284e83410adf7c1c8b6&type=3#extra-long-yellow-highlight-extra-large");
    scale: 1.1 1.1;
}

.button-play:active {
    scale: 1 1;
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Pressed_Sprites/Extra_Large/extra-long-yellow-pressed-extra-large.png?fileID=2800000&guid=4a823e0bc4c64044eb3f80fd8d35dc42&type=3#extra-long-yellow-pressed-extra-large");
}

.button-input {
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Source_Image_Sprites/extra%20large/short-blue-extra-large.png?fileID=2800000&guid=c1186c6c57955e74286697f5a74fa36d&type=3#short-blue-extra-large");
    background-color: rgba(0, 0, 0, 0);
    border-left-color: rgba(0, 0, 0, 0);
    border-right-color: rgba(0, 0, 0, 0);
    border-top-color: rgba(0, 0, 0, 0);
    border-bottom-color: rgba(0, 0, 0, 0);
    font-size: 50px;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap-Medium.ttf?fileID=12800000&guid=7ff5e7a3c5c99c347853c3c23a204c02&type=3#Asap-Medium");
    -unity-text-align: middle-center;
    -unity-font-style: normal;
    width: 150px;
    height: 150px;
}

.button-input:hover {
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Source_Image_Sprites/extra%20large/short-yellow-extra-large.png?fileID=2800000&guid=c8dd6d8869346624c8adc63daa4146b9&type=3#short-yellow-extra-large");
    scale: 1.1 1.1;
    -unity-font-style: bold;
}

.button-input:active {
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Pressed_Sprites/Extra_Large/short-yellow-pressed-extra-large.png?fileID=2800000&guid=2f29148c1d44fcd40a53f8e069862c74&type=3#short-yellow-pressed-extra-large");
    scale: 1 1;
}

.body-text {
    font-size: 35px;
    -unity-text-align: middle-center;
    color: rgb(255, 255, 255);
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_Expanded-BoldItalic.ttf?fileID=12800000&guid=d15f5ad7f8ba57d4c82970eeca851e84&type=3#Asap_Expanded-BoldItalic");
}