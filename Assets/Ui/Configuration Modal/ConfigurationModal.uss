    scale: 1 1;
}

.control-key-text:hover {
    background-color: rgb(115, 96, 168);
}

.horizontal-rule {
    background-color: rgb(255, 255, 255);
    height: 3px;
    margin-top: 0;
    margin-bottom: 50px;
    align-self: flex-start;
}

.slider-label-index {
