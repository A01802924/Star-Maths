.unity-scroll-view__content-container {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
}

.backpack-button {
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Icons/inventory-512.png?fileID=2800000&guid=0bd6fd3c9c173ff438cf0556e5fbf8f0&type=3#inventory-512");
    width: 150px;
    height: 150px;
    -unity-background-scale-mode: scale-to-fit;
    position: absolute;
    top: 2%;
    right: 30%;
}

.backpack-button:hover {
    scale: 1.1 1.1;
}

.header-container {
    background-color: rgb(56, 44, 91);
    padding-top: 5px;
    padding-right: 5px;
    padding-bottom: 5px;
    padding-left: 5px;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
    border-left-color: rgb(255, 255, 255);
    border-right-color: rgb(255, 255, 255);
    border-top-color: rgb(255, 255, 255);
    border-bottom-color: rgb(255, 255, 255);
    border-top-width: 1.5px;
    border-right-width: 1.5px;
    border-bottom-width: 1.5px;
    border-left-width: 1.5px;
}

.header-container:hover {
    background-color: rgb(132, 90, 167);
}
