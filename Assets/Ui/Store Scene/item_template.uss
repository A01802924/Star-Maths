:root {
}

.item_title {
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap-ExtraBoldItalic.ttf?fileID=12800000&guid=5f60ce3fd407f6341a1cc1d1ad778f9c&type=3#Asap-ExtraBoldItalic");
    font-size: 30px;
    color: rgb(255, 255, 255);
    -unity-text-align: middle-center;
}

.item_price {
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_SemiExpanded-ExtraBoldItalic.ttf?fileID=12800000&guid=c32ee0853b2c29c4ea6e3359e1c81f7a&type=3#Asap_SemiExpanded-ExtraBoldItalic");
    font-size: 22px;
