}

.item_container:hover {
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Grid_Components/Large/inventory-highlight-large%201.png?fileID=2800000&guid=84af1e1dff4d84e4da23b7114a108818&type=3#inventory-highlight-large 1");
