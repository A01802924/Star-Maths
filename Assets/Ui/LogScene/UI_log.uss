:root {
}

.contenedor {
    height: 1080px;
}

.miniContenedor {
    width: auto;
    align-items: center;
    background-image: none;
    position: absolute;
    justify-content: center;
    align-content: flex-start;
    align-self: stretch;
    flex-direction: column;
    flex-wrap: nowrap;
}

.inputsLabelInicio {
    flex-wrap: nowrap;
    flex-direction: column;
    width: 400px;
    font-size: 40px;
    border-top-width: 25px;
    border-bottom-width: 25px;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_SemiExpanded-ExtraBoldItalic.ttf?fileID=12800000&guid=c32ee0853b2c29c4ea6e3359e1c81f7a&type=3#Asap_SemiExpanded-ExtraBoldItalic");
    color: rgb(0, 0, 0);
    height: 150px;
}

.botones {
    width: 500px;
    font-size: 45px;
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Source_Image_Sprites/large/large-blue-large.png?fileID=2800000&guid=d44b2578742c2ae40a3ef7a7c2363511&type=3#large-blue-large");
    height: 150px;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_SemiCondensed-Black.ttf?fileID=12800000&guid=52b7e149cd5aff048b3ace8cf0bef3eb&type=3#Asap_SemiCondensed-Black");
    color: rgb(143, 134, 71);
    -unity-background-image-tint-color: rgb(255, 255, 255);
    border-left-color: rgba(56, 56, 56, 0);
    border-right-color: rgba(56, 56, 56, 0);
    border-top-color: rgba(56, 56, 56, 0);
    border-bottom-color: rgba(56, 56, 56, 0);
    transition-duration: 0.35s;
    scale: 1 1;
}

.incio-registro {
    font-size: 30px;
    color: rgb(255, 255, 255);
}

.inputsLabelRegistro {
    flex-direction: column;
    flex-wrap: nowrap;
    width: 400px;
    height: 60px;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_SemiExpanded-ExtraBoldItalic.ttf?fileID=12800000&guid=c32ee0853b2c29c4ea6e3359e1c81f7a&type=3#Asap_SemiExpanded-ExtraBoldItalic");
    color: rgb(0, 0, 0);
    font-size: 23px;
}

.inputsLabelRegistro:active {
}

.titulo {
}

.texto {
    font-size: 40px;
    -unity-font-style: bold-and-italic;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap-Black.ttf?fileID=12800000&guid=55e4db458c396694dbc945bf487b97f0&type=3#Asap-Black");
    color: rgb(255, 255, 255);
    white-space: normal;
}

.botones:hover {
    transition-duration: 0.35s;
    scale: 1.1 1.1;
    color: rgb(252, 255, 213);
}

.exception-text {
    font-size: 27px;
    color: rgb(255, 155, 158);
    -unity-text-align: middle-center;
    -unity-font-style: normal;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_SemiCondensed-SemiBoldItalic.ttf?fileID=12800000&guid=e214a0f6a3dd29b43ac7b0a247b0ab32&type=3#Asap_SemiCondensed-SemiBoldItalic");
}

.close-pop-up {
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Source_Image_Sprites/extra%20large/close-button-extra-large.png?fileID=2800000&guid=a8d80b07a224ab64ea89aa1c2cf2db4c&type=3#close-button-extra-large");
    width: 100px;
    height: 100px;
    border-left-color: rgba(0, 0, 0, 0);
    border-right-color: rgba(0, 0, 0, 0);
    border-top-color: rgba(0, 0, 0, 0);
    border-bottom-color: rgba(0, 0, 0, 0);
    background-color: rgba(0, 0, 0, 0);
    top: 14%;
    right: 10%;
    position: absolute;
}

.close-pop-up:hover {
    scale: 1.1 1.1;
}

.close-pop-up:active {
    scale: 1 1;
}

.accept-pop-up {
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Source_Image_Sprites/extra%20large/short-blue-extra-large.png?fileID=2800000&guid=c1186c6c57955e74286697f5a74fa36d&type=3#short-blue-extra-large");
    background-color: rgba(0, 0, 0, 0);
    border-left-color: rgba(0, 0, 0, 0);
    border-right-color: rgba(0, 0, 0, 0);
    border-top-color: rgba(0, 0, 0, 0);
    border-bottom-color: rgba(0, 0, 0, 0);
    align-self: center;
    font-size: 35px;
    padding-top: 25px;
    padding-right: 50px;
    padding-bottom: 25px;
    padding-left: 50px;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_SemiExpanded-ExtraBoldItalic.ttf?fileID=12800000&guid=c32ee0853b2c29c4ea6e3359e1c81f7a&type=3#Asap_SemiExpanded-ExtraBoldItalic");
    color: rgb(41, 28, 74);
}

.title-pop-up {
    color: rgb(255, 255, 255);
    font-size: 60px;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/Righteous-Regular.ttf?fileID=12800000&guid=3365d868468c1f143aa3fbb4d8a4e397&type=3#Righteous-Regular");
    -unity-text-align: middle-center;
}

.body-pop-up {
    font-size: 45px;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_SemiExpanded-SemiBoldItalic.ttf?fileID=12800000&guid=1de6f60990a8a99428895fdf73d092b6&type=3#Asap_SemiExpanded-SemiBoldItalic");
    white-space: normal;
    color: rgb(255, 255, 255);
    -unity-text-align: middle-center;
}

.radio-button {
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_SemiExpanded-ExtraBoldItalic.ttf?fileID=12800000&guid=c32ee0853b2c29c4ea6e3359e1c81f7a&type=3#Asap_SemiExpanded-ExtraBoldItalic");
    font-size: 25px;
    color: rgb(252, 255, 213);
    -unity-text-align: middle-left;
}

.accept-pop-up:hover {
    scale: 1.1 1.1;
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Highlighted_Sprite/extra%20large/short-blue-highlight-extra-large.png?fileID=2800000&guid=624d474650167f342abc875a633bf3bf&type=3#short-blue-highlight-extra-large");
}

.accept-pop-up:active {
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Button_Images/Pressed_Sprites/Extra_Large/short-blue-pressed-extra-large.png?fileID=2800000&guid=dadfdc6c75932634e8c2206d06746312&type=3#short-blue-pressed-extra-large");
    scale: 1 1;
}

.calendar-button {
    width: 60px;
    height: 60px;
    background-image: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Picto_Icons/White/calendar-256.png?fileID=2800000&guid=745bbb26cf7c26044a9c2c0cb0d1baa6&type=3#calendar-256");
    background-color: rgba(0, 0, 0, 0);
    border-left-color: rgba(0, 0, 0, 0);
    border-right-color: rgba(0, 0, 0, 0);
    border-top-color: rgba(0, 0, 0, 0);
    border-bottom-color: rgba(0, 0, 0, 0);
}

.calendar-button:hover {
    scale: 1.1 1.1;
}

.calendar-button:active {
    scale: 1 1;
}

.label-title-text {
    font-size: 50px;
    color: rgb(252, 255, 213);
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_SemiExpanded-ExtraBoldItalic.ttf?fileID=12800000&guid=c32ee0853b2c29c4ea6e3359e1c81f7a&type=3#Asap_SemiExpanded-ExtraBoldItalic");
}

.label-value-text {
    color: rgb(255, 255, 255);
    font-size: 20px;
    -unity-font-definition: url("project://database/Assets/Sprites/Space_Exploration_GUI_Kit/Fonts/Font%20Sources/static/Asap_SemiExpanded-ExtraBoldItalic.ttf?fileID=12800000&guid=c32ee0853b2c29c4ea6e3359e1c81f7a&type=3#Asap_SemiExpanded-ExtraBoldItalic");
}

.unity-radio-button-group__container {
    flex-direction: row;
    justify-content: space-around;
}
